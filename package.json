{
  "name": "cove",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp run check && vp run test && vp run -r build",
    "check": "vp run web#generate:api && vp check",
    "test": "vp run web#generate:api && vp run --filter './packages/**' --filter './apps/api' test && vp run web#test && vp run @cove/acceptance#test",
    "dev": "vp run web#dev",
    "prepare": "vp config && vp run web#generate:api",
    "doctor": "npx react-doctor@latest"
  },
  "devDependencies": {
    "react-doctor": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
