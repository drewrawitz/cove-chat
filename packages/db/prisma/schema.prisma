datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER  @map("owner")
  ADMIN  @map("admin")
  MEMBER @map("member")
  GUEST  @map("guest")
}

enum ChannelVisibility {
  PUBLIC  @map("public")
  PRIVATE @map("private")
}

model User {
  id                  String              @id
  email               String              @unique
  displayName         String              @map("display_name")
  workspaceIdentities WorkspaceIdentity[]
  magicLinks          MagicLink[]
  sessions            Session[]
  auditEvents         AuditEvent[]
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("users")
}

model MagicLink {
  tokenHash  String    @id @map("token_hash")
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("magic_links")
}

model Session {
  tokenHash     String   @id @map("token_hash")
  csrfTokenHash String   @unique @map("csrf_token_hash")
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt     DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditEvent {
  id           String   @id
  eventType    String   @map("event_type")
  eventVersion Int      @map("event_version")
  actorUserId  String   @map("actor_user_id")
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  occurredAt   DateTime @map("occurred_at") @db.Timestamptz(6)
  metadata     Json     @db.JsonB

  @@index([actorUserId, occurredAt])
  @@map("audit_events")
}

model Workspace {
  id         String              @id
  name       String
  identities WorkspaceIdentity[]
  channels   Channel[]
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("workspaces")
}

model WorkspaceIdentity {
  id                  String
  workspaceId         String              @map("workspace_id")
  accountId           String              @map("account_id")
  name                String
  avatarUrl           String              @map("avatar_url")
  role                WorkspaceRole       @default(MEMBER)
  membershipStartedAt DateTime            @default(now()) @map("membership_started_at") @db.Timestamptz(6)
  membershipEndedAt   DateTime?           @map("membership_ended_at") @db.Timestamptz(6)
  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account             User                @relation(fields: [accountId], references: [id], onDelete: Restrict)
  channelMemberships  ChannelMembership[]
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, id])
  @@unique([workspaceId, accountId])
  @@index([accountId])
  @@index([workspaceId, membershipEndedAt])
  @@map("workspace_identities")
}

model Channel {
  id          String
  workspaceId String              @map("workspace_id")
  name        String
  visibility  ChannelVisibility   @default(PUBLIC)
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships ChannelMembership[]
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, id])
  @@index([workspaceId, visibility])
  @@map("channels")
}

model ChannelMembership {
  workspaceId       String            @map("workspace_id")
  channelId         String            @map("channel_id")
  identityId        String            @map("identity_id")
  channel           Channel           @relation(fields: [workspaceId, channelId], references: [workspaceId, id], onDelete: Cascade)
  workspaceIdentity WorkspaceIdentity @relation(fields: [workspaceId, identityId], references: [workspaceId, id], onDelete: Cascade)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, channelId, identityId])
  @@index([workspaceId, identityId])
  @@map("channel_memberships")
}
