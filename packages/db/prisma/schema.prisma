datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER  @map("owner")
  ADMIN  @map("admin")
  MEMBER @map("member")
}

enum ChannelVisibility {
  PUBLIC  @map("public")
  PRIVATE @map("private")
}

model User {
  id                   String                @id
  email                String                @unique
  displayName          String                @map("display_name")
  workspaceMemberships WorkspaceMembership[]
  magicLinks           MagicLink[]
  sessions             Session[]
  auditEvents          AuditEvent[]
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("users")
}

model MagicLink {
  tokenHash  String    @id @map("token_hash")
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("magic_links")
}

model Session {
  tokenHash     String   @id @map("token_hash")
  csrfTokenHash String   @unique @map("csrf_token_hash")
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt     DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditEvent {
  id          String   @id
  eventType   String   @map("event_type")
  actorUserId String   @map("actor_user_id")
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  occurredAt  DateTime @map("occurred_at") @db.Timestamptz(6)

  @@index([actorUserId, occurredAt])
  @@map("audit_events")
}

model Workspace {
  id          String                @id
  name        String
  memberships WorkspaceMembership[]
  channels    Channel[]
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("workspaces")
}

model WorkspaceMembership {
  workspaceId        String              @map("workspace_id")
  userId             String              @map("user_id")
  role               WorkspaceRole       @default(MEMBER)
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelMemberships ChannelMembership[]
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_memberships")
}

model Channel {
  id          String
  workspaceId String              @map("workspace_id")
  name        String
  visibility  ChannelVisibility   @default(PUBLIC)
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships ChannelMembership[]
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, id])
  @@index([workspaceId, visibility])
  @@map("channels")
}

model ChannelMembership {
  workspaceId         String              @map("workspace_id")
  channelId           String              @map("channel_id")
  userId              String              @map("user_id")
  channel             Channel             @relation(fields: [workspaceId, channelId], references: [workspaceId, id], onDelete: Cascade)
  workspaceMembership WorkspaceMembership @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Cascade)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, channelId, userId])
  @@index([workspaceId, userId])
  @@map("channel_memberships")
}
