datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER  @map("owner")
  ADMIN  @map("admin")
  MEMBER @map("member")
  GUEST  @map("guest")
}

enum ChannelVisibility {
  PUBLIC  @map("public")
  PRIVATE @map("private")
}

enum TopicIntent {
  QUESTION   @map("question")
  PROPOSAL   @map("proposal")
  DECISION   @map("decision")
  UPDATE     @map("update")
  DISCUSSION @map("discussion")
}

model User {
  id                  String                @id
  email               String                @unique
  displayName         String                @map("display_name")
  workspaceIdentities WorkspaceIdentity[]
  magicLinks          MagicLink[]
  sessions            Session[]
  auditEvents         AuditEvent[]
  invitationsSent     WorkspaceInvitation[] @relation("WorkspaceInvitationInviter")
  invitationsAccepted WorkspaceInvitation[] @relation("WorkspaceInvitationAccepter")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("users")
}

model MagicLink {
  tokenHash  String    @id @map("token_hash")
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("magic_links")
}

model Session {
  tokenHash     String   @id @map("token_hash")
  csrfTokenHash String   @unique @map("csrf_token_hash")
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt     DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditEvent {
  id           String   @id
  eventType    String   @map("event_type")
  eventVersion Int      @map("event_version")
  actorUserId  String   @map("actor_user_id")
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  occurredAt   DateTime @map("occurred_at") @db.Timestamptz(6)
  metadata     Json     @db.JsonB

  @@index([actorUserId, occurredAt])
  @@map("audit_events")
}

model Workspace {
  id          String                @id
  name        String
  identities  WorkspaceIdentity[]
  channels    Channel[]
  invitations WorkspaceInvitation[]
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("workspaces")
}

model WorkspaceInvitation {
  id                  String        @id
  workspaceId         String        @map("workspace_id")
  inviteeEmail        String        @map("invitee_email")
  invitedByAccountId  String        @map("invited_by_account_id")
  acceptedByAccountId String?       @map("accepted_by_account_id")
  tokenHash           String        @unique @map("token_hash")
  tokenExpiresAt      DateTime      @map("token_expires_at") @db.Timestamptz(6)
  role                WorkspaceRole @default(MEMBER)
  invitedAt           DateTime      @default(now()) @map("invited_at") @db.Timestamptz(6)
  acceptedAt          DateTime?     @map("accepted_at") @db.Timestamptz(6)
  workspace           Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy           User          @relation("WorkspaceInvitationInviter", fields: [invitedByAccountId], references: [id], onDelete: Restrict)
  acceptedBy          User?         @relation("WorkspaceInvitationAccepter", fields: [acceptedByAccountId], references: [id], onDelete: Restrict)

  @@index([inviteeEmail, acceptedAt])
  @@index([acceptedByAccountId])
  @@index([tokenExpiresAt])
  @@index([workspaceId, acceptedAt])
  @@map("workspace_invitations")
}

model WorkspaceIdentity {
  id                  String
  workspaceId         String              @map("workspace_id")
  accountId           String              @map("account_id")
  name                String
  avatarUrl           String              @map("avatar_url")
  role                WorkspaceRole       @default(MEMBER)
  membershipStartedAt DateTime            @default(now()) @map("membership_started_at") @db.Timestamptz(6)
  membershipEndedAt   DateTime?           @map("membership_ended_at") @db.Timestamptz(6)
  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account             User                @relation(fields: [accountId], references: [id], onDelete: Restrict)
  channelMemberships  ChannelMembership[]
  maintainedChannels  Channel[]           @relation("ChannelMaintainer")
  openedTopics        Topic[]             @relation("TopicOpener")
  messages            Message[]           @relation("MessageAuthor")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, id])
  @@unique([workspaceId, accountId])
  @@index([accountId])
  @@index([workspaceId, membershipEndedAt])
  @@map("workspace_identities")
}

model Channel {
  id                   String
  workspaceId          String              @map("workspace_id")
  name                 String
  purpose              String              @default("Purpose not recorded.")
  visibility           ChannelVisibility   @default(PUBLIC)
  maintainerIdentityId String              @map("maintainer_identity_id")
  workspace            Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  maintainer           WorkspaceIdentity   @relation("ChannelMaintainer", fields: [workspaceId, maintainerIdentityId], references: [workspaceId, id], onDelete: Restrict)
  memberships          ChannelMembership[]
  topics               Topic[]
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, id])
  @@index([workspaceId, visibility])
  @@index([workspaceId, maintainerIdentityId])
  @@map("channels")
}

model ChannelMembership {
  workspaceId       String            @map("workspace_id")
  channelId         String            @map("channel_id")
  identityId        String            @map("identity_id")
  channel           Channel           @relation(fields: [workspaceId, channelId], references: [workspaceId, id], onDelete: Cascade)
  workspaceIdentity WorkspaceIdentity @relation(fields: [workspaceId, identityId], references: [workspaceId, id], onDelete: Cascade)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, channelId, identityId])
  @@index([workspaceId, identityId])
  @@map("channel_memberships")
}

model Topic {
  id                 String
  workspaceId        String            @map("workspace_id")
  channelId          String            @map("channel_id")
  title              String
  intent             TopicIntent?
  openedByIdentityId String            @map("opened_by_identity_id")
  channel            Channel           @relation(fields: [workspaceId, channelId], references: [workspaceId, id], onDelete: Cascade)
  openedBy           WorkspaceIdentity @relation("TopicOpener", fields: [workspaceId, openedByIdentityId], references: [workspaceId, id], onDelete: Restrict)
  messages           Message[]
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([workspaceId, id])
  @@index([workspaceId, channelId, createdAt])
  @@index([workspaceId, openedByIdentityId])
  @@map("topics")
}

model Message {
  id               String
  workspaceId      String            @map("workspace_id")
  topicId          String            @map("topic_id")
  authorIdentityId String            @map("author_identity_id")
  body             String?
  position         Int
  topic            Topic             @relation(fields: [workspaceId, topicId], references: [workspaceId, id], onDelete: Cascade)
  author           WorkspaceIdentity @relation("MessageAuthor", fields: [workspaceId, authorIdentityId], references: [workspaceId, id], onDelete: Restrict)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  editedAt         DateTime?         @map("edited_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  revisions        MessageRevision[]

  @@id([workspaceId, topicId, id])
  @@unique([workspaceId, topicId, position])
  @@index([workspaceId, authorIdentityId])
  @@map("messages")
}

model MessageRevision {
  id          BigInt                   @id @default(autoincrement())
  workspaceId String                   @map("workspace_id")
  topicId     String                   @map("topic_id")
  messageId   String                   @map("message_id")
  body        String
  operation   MessageRevisionOperation
  revisedAt   DateTime                 @map("revised_at") @db.Timestamptz(6)
  message     Message                  @relation(fields: [workspaceId, topicId, messageId], references: [workspaceId, topicId, id], onDelete: Restrict)

  @@index([workspaceId, topicId, messageId, id])
  @@map("message_revisions")
}

enum MessageRevisionOperation {
  edit
  delete
}
